---
import { Image } from 'astro:assets';
import '../styles/global.css';
import logo from '/src/assets/logo.svg';
import Nav from './nav.astro';
import HfLayout from '../layouts/hf-layout.astro';

const { title } = Astro.props;

---

<HfLayout as="header">
  <div class="wrapper">
    <a class="logo" href="/">
      <!-- <Image src={logo} alt="logo" > -->
    </a>
    <h2>{ title }</h2>
    <Nav />
  </div>
</HfLayout>

<style>
 .wrapper {
    box-sizing: border-box;
    min-height: 5em;
    width: 100%;
    margin: 1em auto;
    padding: 1em;
    box-shadow: var(--shadow);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
  }

  .inner-wrapper {
    display: flex;
    width: fit-content;
  }

  .logo {
    width: 60%;
    max-width: 50px;
    max-height: 100px;
    padding: 0 2em;
  }

  .logo img {
    height: auto;
    width: 100%;
    max-height: 200px;
  }
</style>
