---
import { Image } from "astro:assets";
import '../styles/global.css';

interface Props {
  title: string
  stack: string[]
  desc: string
  img: string
  alt: string
  link: string
}

const { title, stack, desc, img, alt, link } = Astro.props
---

<a class="tile" href=`/projects/${link}`>
  <Image src={img}  alt={alt} width=100 height=100 class="img"/>
  <div class="info">
      <h3>{ title }</h3>
      <p>{ desc }</p>
      <ul>{ stack.map(s => <li>{s}</li>) }</ul>
  </div>
</a>

<style>
    
.tile {
  display: flex;
  align-items: center;
  background-color: var(--surface);
  border-radius: var(--radius);
  padding: 1em 2em;
  margin: 1em 0;
  gap: 2em;
  box-shadow: var(--text) 2px 2px 10px -2px;
  text-decoration: none;
  color: var(--text);
  transition: background-color .3s ease;
}

.tile:hover {
  background-color: var(--accent);
  color: #fff;
}

ul {
  padding: 1em;
}

.img {
  border-radius: var(--radius);
}

.info {
  padding: 0 1em;
}

@media (max-width: 1300px) {
  .tile {
    padding: 0.5em 1em;
    gap: 1em;
  }
}

@media (max-width: 450px) {
  .img {
    display: none;
  }
}
</style>
