---
import { Image } from "astro:assets";
import '../styles/global.css';

interface Props {
  title: string
  stack: string[]
  desc: string
  img: string
  alt: string
  link: string
}

const { title, stack, desc, img, alt, link } = Astro.props
---

<a class="tile" href=`projects/${link}`>
  <Image src={img}  alt={alt} width=100 height=100 class="img"/>
  <div class="info">
      <h3>{ title }</h3>
      <p>{ desc }</p>
      <ul>{ stack.map(s => <li>{s}</li>) }</ul>
  </div>
</a>

<style>
    
.tile {
    display: flex;
    background-color: var(--surface);
    border-radius: var(--radius);
    padding: 1em 2em;
    margin: 1em 0;
    gap: 2em;
    box-shadow: var(--text) 2px 2px 10px -2px;
    text-decoration: none;
    color: var(--text);
}

.tile:hover {
  transform: scale(1.01);
  background-color: var(--accent);
}

.img {
  border-radius: 50%;
}
</style>
