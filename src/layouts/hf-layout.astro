---
type TagType = 'header' | 'footer';
const { as = 'header' } : { as?: TagType } = Astro.props
const Tag = as
---

<Tag class="tag">
    <slot />
</Tag>

<style>

  .tag {
    background-color: var(--surface);
    box-shadow: var(--shadow);
    border-radius: var(--radius);
    margin: 1em 0;
  }

</style>
